# ── Cherish Consulting · Environment Variables ───────────────
#
# Copy this file to .env.local for local development.
# In production, set these in Vercel:
#   Settings → Environment Variables
#
# ─────────────────────────────────────────────────────────────

# Admin dashboard master key
# Required to access /admin  (analytics config + blog panel)
# Choose any passphrase — avoid using real passwords or API tokens.
VITE_ADMIN_KEY=change-me-to-something-strong
